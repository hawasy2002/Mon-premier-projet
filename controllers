const path = require('path');
const pool = require(path.join(__dirname, '..', 'config', 'database'));
const { OAuth2Client } = require('google-auth-library');
const { validationResult } = require('express-validator');
const User = require(path.join(__dirname, '..', 'models', 'User'));
const { authLocal } = require(path.join(__dirname, '..', 'middlewares', 'authMiddleware'));
const logger = require(path.join(__dirname, '..', 'middlewares', 'errorHandler'));
// GOOGLE OAUTH 
const client = new OAuth2Client(
  process.env.GOOGLE_CLIENT_ID,
  process.env.GOOGLE_CLIENT_SECRET,
  process.env.REDIRECT_URI
);
 
async function authGoogle(profile) {
  const googleId = profile.id;
  const email = profile.emails[0].value;
  const nom = profile.name.familyName || 'Inconnu';
  const prenom = profile.name.givenName || 'Utilisateur';

  try {
    // Vérifie si un utilisateur avec ce Google ID existe déjà
    const [googleMatch] = await pool.query(
      "SELECT id_user AS id, nom, prenom, email, role FROM users WHERE googleId = ?",
      [googleId]
    );

    if (googleMatch.length > 0) {
      return googleMatch[0]; // Déjà inscrit via Google
    }

    // Sinon, vérifie s’il existe déjà via email
    const [emailMatch] = await pool.query(
      "SELECT id_user AS id, nom, prenom, email, role, googleId FROM users WHERE email = ?",
      [email]
    );

    if (emailMatch.length > 0) {
      const user = emailMatch[0];

      // Si le googleId est vide, on le met à jour
      if (!user.googleId) {
        await pool.query("UPDATE users SET googleId = ? WHERE id_user = ?", [googleId, user.id]);
      }

      return {
        id: user.id,
        nom: user.nom,
        prenom: user.prenom,
        email: user.email,
        role: user.role
      };
    }

    // Sinon, création d’un nouvel utilisateur
    const [insert] = await pool.query(
      "INSERT INTO users (googleId, nom, prenom, email, role) VALUES (?, ?, ?, ?, ?)",
      [googleId, nom, prenom, email, 'user']
    );

    const [newUserRows] = await pool.query(
      "SELECT id_user AS id, nom, prenom, email, role FROM users WHERE id_user = ?",
      [insert.insertId]
    );

    return newUserRows[0];

  } catch (error) {
    console.error(" Erreur authGoogle:", error);
    throw new Error("Erreur lors de l'authentification Google");
  }
}


exports.redirectToGoogle = (req, res) => {
  const authUrl = `https://accounts.google.com/o/oauth2/v2/auth?` +
    `client_id=${process.env.GOOGLE_CLIENT_ID}&` +
    `redirect_uri=${encodeURIComponent(process.env.REDIRECT_URI)}&` +
    `response_type=code&` +
    `scope=profile%20email&` +
    `access_type=offline&` +
    `prompt=select_account`;

  res.redirect(authUrl);
};

exports.handleGoogleCallback = async (req, res) => {
  if (!req.query.code) {
    req.session.error = 'Autorisation Google refusée';
    return res.redirect('/login');
  }

  try {
    const { tokens } = await client.getToken({
      code: req.query.code,
      client_id: process.env.GOOGLE_CLIENT_ID,
      client_secret: process.env.GOOGLE_CLIENT_SECRET,
      redirect_uri: process.env.REDIRECT_URI
    });

    const ticket = await client.verifyIdToken({
      idToken: tokens.id_token,
      audience: process.env.GOOGLE_CLIENT_ID
    });

    const profile = ticket.getPayload();

    if (!profile.email_verified) {
      throw new Error('Email Google non vérifié');
    }

    const user = await authGoogle({
      id: profile.sub,
      name: {
        givenName: profile.given_name,
        familyName: profile.family_name
      },
      emails: [{ value: profile.email }]
    });

    req.session.user = {
      id: user.id,
      nom: user.nom,
      prenom: user.prenom,
      email: user.email,
      role: user.role
    };

    req.session.save(err => {
  if (err) {
    console.error('Erreur sauvegarde session:', err);
  }
  req.session.success = `Bienvenue ${user.prenom || user.nom} !`;
  res.redirect('/accueil');
});

    
