// INSCRIPTION CLASSIQUE 
exports.classicRegister = async (req, res) => {
  const errors = validationResult(req);
  if (!errors.isEmpty()) {
    req.session.errors = errors.array();
    return res.redirect('/signup');
  }

  const { email, nom, prenom, password: mdp } = req.body;

  try {
    const existingUser = await User.findByEmail(email);
    if (existingUser) {
      req.session.error = 'Cet email est déjà utilisé';
      return res.redirect('/signup');
    }

    const userId = await User.createWithPassword({ email, nom, prenom, mdp, role: 'user' });
    const user = await User.findById(userId);

    req.session.user = {
      id: user.id,
      nom: user.nom,
      prenom: user.prenom,
      email: user.email,
      role: user.role
    };

    req.session.success = 'Inscription réussie';
    res.redirect('/accueil');
  } catch (error) {
    logger.error('Erreur inscription', {
      error: error.message,
      stack: error.stack,
      userData: { email }
    });

    req.session.error = 'Erreur lors de l’inscription';
    res.redirect('/signup');
  }
};

// CONNEXION CLASSIQUE 
exports.classicLogin = async (req, res) => {
  try {
    const { email, password } = req.body;
    const user = await authLocal(email, password);

    req.session.user = {
      id: user.id,
      nom: user.nom,
      prenom: user.prenom,
      email: user.email,
      role: user.role
    };

    req.session.success = 'Connexion réussie';
    console.log('✅ Session après login:', req.session.user);
    res.redirect('/accueil');
  } catch (error) {
    req.session.error = error.message.includes('incorrect') ?
      'Email ou mot de passe incorrect.' :
      'Erreur de connexion.';
    res.redirect('/login');
  }
};

//  DÉCONNEXION 
exports.logout = (req, res) => {
  req.session.destroy(err => {
    if (err) {
      console.error('Erreur déconnexion:', err);
      req.session.error = 'Erreur lors de la déconnexion';
      return res.redirect('/');
    }
    res.clearCookie('connect.sid');
    res.redirect('/login');
  });
};
