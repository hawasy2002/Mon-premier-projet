
function logger(req, res, next) {
  console.log(`${req.method} ${req.url}`);
  next(); 
  
const express = require('express');
const app = express();

app.use(logger); 

app.get('/', (req, res) => {
  res.send('Bienvenue sur mon projet !');
});

app.listen(3000, () => {
  console.log('Serveur démarré sur http://localhost:3000');
});
